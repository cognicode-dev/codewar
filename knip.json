{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": "commitlint.config.js"
    },
    "apps/*": {
      "entry": ["src/app/page.tsx", "src/app/layout.tsx", "next.config.mjs"]
    },
    "services/*": {
      "entry": "src/index.ts"
    },
    "packages/ui": {
      "entry": "src/index.tsx"
    },
    "packages/*": {
      "entry": "src/index.ts"
    }
  }
}
