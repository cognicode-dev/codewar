datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  passwordHash  String
  coins         Int            @default(0)
  streak        Int            @default(0)
  emailVerified Boolean        @default(false)
  verificationToken         String?   @unique
  verificationTokenExpires  DateTime?
  resetPasswordToken        String?   @unique
  resetPasswordTokenExpires DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  profile       Profile?
  submissions   Submission[]
  ratings       UserRating[]
  ratingHistories RatingHistory[]
  relationships       UserRelationship[] @relation("UserRelationships")
  targetRelationships UserRelationship[] @relation("TargetUserRelationships")
  conversations       ConversationParticipant[]
  messagesSent        Message[]

  @@index([username])
  @@index([email])
  @@index([verificationToken])
  @@index([resetPasswordToken])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Profile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName    String?
  avatarUrl      String?
  bio            String?
  visibility     String   @default("PUBLIC") // PUBLIC, PRIVATE, FRIENDS_ONLY
  
  // Preferences
  theme          String   @default("DARK")
  language       String   @default("EN")
  editorSettings Json?
  
  // Statistics
  xp             Int      @default(0)
  level          Int      @default(1)
  gamesPlayed    Int      @default(0)
  gamesWon       Int      @default(0)
  
  // Social Links
  githubUrl      String?
  linkedinUrl    String?
  websiteUrl     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Problem {
  id          String           @id @default(uuid())
  slug        String           @unique
  title       String
  difficulty  String           // EASY, MEDIUM, HARD
  tags        String[]
  visibility  String           // PUBLIC, PRIVATE, DRAFT
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  versions    ProblemVersion[]
  submissions Submission[]

  @@index([slug])
  @@index([difficulty])
}

model ProblemVersion {
  id             String   @id @default(uuid())
  problemId      String
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  version        Int
  statement      String   // Markdown description of the problem
  constraints    String   // Markdown description of the constraints
  timeLimit      Int      // Time limit in milliseconds
  memoryLimit    Int      // Memory limit in MB
  examples       Json     // Array of example inputs/outputs/explanations
  testCases      Json     // Array of hidden test cases used by the judge
  languages      Json     // Code templates for supported languages
  editorial      String?  // Markdown description of the solution
  createdAt      DateTime @default(now())

  @@unique([problemId, version])
  @@index([problemId])
}

enum SubmissionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Submission {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId      String
  problem        Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemVersion Int
  code           String
  language       String
  status         SubmissionStatus @default(PENDING)
  verdict        String?
  timeMs         Int?
  memoryMb       Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  jobs           SubmissionJob[]

  @@index([userId])
  @@index([problemId])
}

model SubmissionJob {
  id             String           @id @default(uuid())
  submissionId   String
  submission     Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status         SubmissionStatus @default(PENDING)
  verdict        String?
  timeMs         Int?
  memoryMb       Int?
  error          String?
  results        Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([submissionId])
}

enum DbMatchStatus {
  COUNTDOWN
  ACTIVE
  FINISHED
  ABORTED
}

model Match {
  id             String             @id @default(uuid())
  roomId         String
  problemId      String
  status         DbMatchStatus
  winnerUserId   String?
  winnerTeam     String?
  startedAt      DateTime?
  finishedAt     DateTime?
  abortedAt      DateTime?
  abortedReason  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  participants   MatchParticipant[]
  timeline       MatchEvent[]
  ratingHistories RatingHistory[]

  @@index([roomId])
  @@index([problemId])
}

model MatchParticipant {
  id           String    @id @default(uuid())
  matchId      String
  match        Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId       String
  team         String?
  result       String?   // "WON", "LOST", "DRAW", "ABORTED"
  ratingChange Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([matchId])
  @@index([userId])
}

model MatchEvent {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      String
  data      Json
  timestamp DateTime @default(now())

  @@index([matchId])
}

model Season {
  id              String          @id @default(uuid())
  number          Int             @unique
  name            String
  status          String          // "ACTIVE", "FINISHED"
  startedAt       DateTime        @default(now())
  endedAt         DateTime?
  ratings         UserRating[]
  ratingHistories RatingHistory[]
}

model UserRating {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  seasonId         String
  season           Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  rating           Int      @default(1000)
  placementMatches Int      @default(0)
  isPlaced         Boolean  @default(false)
  lastMatchAt      DateTime @default(now())

  @@unique([userId, seasonId])
  @@index([userId])
  @@index([seasonId])
  @@index([rating])
}

model RatingHistory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  seasonId     String
  season       Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  matchId      String?
  match        Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)
  oldRating    Int
  newRating    Int
  ratingChange Int
  changeReason String   // "MATCH_RESULT", "DECAY"
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([seasonId])
  @@index([matchId])
}

model UserRelationship {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation("UserRelationships", fields: [userId], references: [id], onDelete: Cascade)
  targetUserId String
  targetUser   User     @relation("TargetUserRelationships", fields: [targetUserId], references: [id], onDelete: Cascade)
  status       String   // "PENDING", "FRIENDS", "BLOCKED"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, targetUserId])
  @@index([userId])
  @@index([targetUserId])
}

model Conversation {
  id           String                    @id @default(uuid())
  type         String                    // "DIRECT", "PARTY", "ROOM", "SYSTEM"
  createdAt    DateTime                  @default(now())
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  timestamp      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([timestamp])
}
